<Window x:Class="CodexQuota.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CodexQuota"
        Width="300"
        Height="158"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="立即刷新" Click="RefreshMenuItem_Click" />
            <MenuItem x:Name="AlwaysOnTopMenuItem" Header="始终置顶" IsCheckable="True" Click="AlwaysOnTopMenuItem_Click" />
            <MenuItem x:Name="LockPositionMenuItem" Header="锁定位置" IsCheckable="True" Click="LockPositionMenuItem_Click" />
            <MenuItem x:Name="StartWithWindowsMenuItem" Header="开机启动" IsCheckable="True" Click="StartWithWindowsMenuItem_Click" />
            <Separator />
            <MenuItem Header="打开日志目录" Click="OpenLogsMenuItem_Click" />
            <MenuItem Header="关于" Click="AboutMenuItem_Click" />
            <Separator />
            <MenuItem Header="退出" Click="ExitMenuItem_Click" />
        </ContextMenu>
    </Window.ContextMenu>

    <Border CornerRadius="18"
            BorderBrush="#3B82F6"
            BorderThickness="1"
            Padding="16,12"
            MouseLeftButtonDown="Window_MouseLeftButtonDown"
            MouseLeftButtonUp="Window_MouseLeftButtonUp">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F0181D2A" Offset="0" />
                <GradientStop Color="#F00B1220" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Codex Quota"
                           Foreground="#E2E8F0"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusTextBlock"
                               Text="●"
                               Foreground="#EF4444"
                               FontSize="12"
                               Margin="0,0,5,0" />
                    <TextBlock x:Name="ChatGptStatusTextBlock"
                               Text="ChatGPT 离线"
                               Foreground="#94A3B8"
                               FontSize="11" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,7,0,7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="本周余量"
                               Foreground="#94A3B8"
                               FontSize="13" />
                    <TextBlock x:Name="WeeklyResetTextBlock"
                               Text="读取中…"
                               Foreground="#CBD5E1"
                               FontSize="12"
                               Margin="0,5,0,0" />
                </StackPanel>

                <Border x:Name="WeeklyPercentPill"
                        Grid.Column="1"
                        CornerRadius="14"
                        Padding="13,1"
                        Background="Transparent"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="WeeklyPercentTextBlock"
                               Text="--"
                               FontWeight="Black"
                               FontSize="42"
                               Foreground="#F8FAFC"
                               HorizontalAlignment="Center" />
                </Border>
            </Grid>

            <ProgressBar x:Name="WeeklyProgressBar"
                         Grid.Row="2"
                         Height="7"
                         Minimum="0"
                         Maximum="100"
                         Value="0"
                         Foreground="#22C55E"
                         Background="#263244" />

            <Grid Grid.Row="3" Margin="0,9,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="只显示 Codex 写入的真实周额度"
                           Foreground="#64748B"
                           FontSize="10.5" />
                <TextBlock x:Name="ObservedTextBlock"
                           Grid.Column="1"
                           Text="未绑定"
                           Foreground="#64748B"
                           FontSize="10.5" />
            </Grid>
        </Grid>
    </Border>
</Window>
