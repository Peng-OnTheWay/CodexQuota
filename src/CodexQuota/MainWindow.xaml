<Window x:Class="CodexQuota.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CodexQuota"
        Width="120"
        Height="210"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="立即刷新" Click="RefreshMenuItem_Click" />
            <MenuItem x:Name="AlwaysOnTopMenuItem" Header="始终置顶" IsCheckable="True" Click="AlwaysOnTopMenuItem_Click" />
            <MenuItem x:Name="LockPositionMenuItem" Header="锁定位置" IsCheckable="True" Click="LockPositionMenuItem_Click" />
            <MenuItem x:Name="StartWithWindowsMenuItem" Header="开机启动" IsCheckable="True" Click="StartWithWindowsMenuItem_Click" />
            <Separator />
            <MenuItem Header="打开日志目录" Click="OpenLogsMenuItem_Click" />
            <MenuItem Header="关于" Click="AboutMenuItem_Click" />
            <Separator />
            <MenuItem Header="退出" Click="ExitMenuItem_Click" />
        </ContextMenu>
    </Window.ContextMenu>

    <Border CornerRadius="12"
            Background="{StaticResource PanelBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Padding="14,5"
            MouseLeftButtonDown="Window_MouseLeftButtonDown"
            MouseLeftButtonUp="Window_MouseLeftButtonUp">
        <StackPanel VerticalAlignment="Center">
            <!-- 5小时 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                <TextBlock x:Name="StatusTextBlock"
                           Text="●"
                           Foreground="#86EFAC"
                           FontSize="12"
                           Margin="0,0,6,0"
                           VerticalAlignment="Center" />
                <TextBlock Text="5小时"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13"
                           VerticalAlignment="Center" />
            </StackPanel>
            <Border x:Name="FiveHourPercentPill"
                    CornerRadius="6"
                    Padding="8,2"
                    Background="Transparent"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,1">
                <TextBlock x:Name="FiveHourPercentTextBlock"
                           Text="--"
                           FontWeight="Black"
                           FontSize="28"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" />
            </Border>
            <TextBlock x:Name="FiveHourResetTextBlock"
                       Text=""
                       Foreground="#94A3B8"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,3" />

            <!-- 分割线 -->
            <Border Height="1"
                    Background="#334155"
                    Margin="8,4,8,2"
                    Width="80"
                    HorizontalAlignment="Center" />

            <!-- 本周 -->
            <TextBlock Text="本周"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0" />
            <Border x:Name="WeeklyPercentPill"
                    CornerRadius="6"
                    Padding="8,2"
                    Background="Transparent"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,1">
                <TextBlock x:Name="WeeklyPercentTextBlock"
                           Text="--"
                           FontWeight="Black"
                           FontSize="28"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" />
            </Border>
            <TextBlock x:Name="WeeklyResetTextBlock"
                       Text=""
                       Foreground="#94A3B8"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,3" />

            <!-- Codex 日志时间 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,4">
                <TextBlock Text="Codex"
                           Foreground="#64748B"
                           FontSize="11"
                           Margin="0,0,4,0"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="ObservedTextBlock"
                           Text=""
                           Foreground="#64748B"
                           FontSize="11"
                           VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
