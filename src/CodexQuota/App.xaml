<Application x:Class="CodexQuota.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#E51A1E27" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#CBD5E1" />
        <SolidColorBrush x:Key="BorderBrush" Color="#334155" />
    </Application.Resources>
</Application>
